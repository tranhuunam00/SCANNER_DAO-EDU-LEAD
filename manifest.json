{
  "manifest_version": 3,
  "name": "DAO EDU Lead Scanner",
  "version": "2.0.0",
  "description": "Quet bai viet va binh luan dang hien thi tren Facebook de thu nghiem lead tuyen sinh.",
  "permissions": [
    "activeTab",
    "storage",
    "downloads",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://www.facebook.com/*",
    "https://web.facebook.com/*",
    "https://m.facebook.com/*",
    "https://*/*",
    "http://*/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "action": {
    "default_title": "DAO EDU Lead Scanner",
    "default_popup": "index.html"
  },
  "background": {
    "service_worker": "src/background/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.facebook.com/*"
      ],
      "js": [
        "src/content/batch-queue.js",
        "src/content/content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
